# Normalización automática de finales de línea
* text=auto

# Scripts shell: siempre LF (requerido para Linux/Contenedores)
*.sh text eol=lf
*.bash text eol=lf

# Archivos de Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Configuración de CI/CD y orquestación
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.tf text eol=lf
*.tfvars text eol=lf

# Documentación
*.md text eol=lf
*.svg text eol=lf
*.drawio text eol=lf

# Código fuente
*.java text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.http text eol=lf

# Maven wrapper: obligatorio LF para Linux runner
mvnw text eol=lf
.mvn/** text eol=lf

# Scripts batch Windows: CRLF obligatorio
*.cmd text eol=crlf
*.bat text eol=crlf
